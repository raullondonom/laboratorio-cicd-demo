{
  "name": "lab-cicd-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "eslint src --ext ts,tsx --max-warnings 0",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
