# Copia este archivo a .env y ajusta los valores si quieres.
# docker-compose lee automáticamente .env del directorio actual.

# --- PostgreSQL ---
POSTGRES_USER=labuser
POSTGRES_PASSWORD=labpass
POSTGRES_DB=labdb
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Backend ---
BACKEND_PORT=8000
# URL de conexión que usa SQLAlchemy dentro del contenedor backend
DATABASE_URL=postgresql+psycopg://labuser:labpass@db:5432/labdb

# --- Frontend ---
FRONTEND_PORT=5173
# La SPA consume la API por esta URL pública (host del usuario, NO el nombre de servicio Docker)
VITE_API_URL=http://localhost:8000

# --- pgAdmin ---
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin
